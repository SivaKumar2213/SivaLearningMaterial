package com.Assert.TimeOut;

import static org.junit.jupiter.api.Assertions.*;

import java.time.Duration;

import org.junit.jupiter.api.Test;
//assertTimeout was introduced in Junit5 
//in Junit4 we can use @Test(Time=100)
//If the task completed within the time provided it will pass the case
//or else it is exceeding the time it will fail the case
class sortedArrayTestForassertTimout {
	sortedArrayinLoop sa=new sortedArrayinLoop();	
	@Test
	void test() {
		int num[]= {2,6,1,3,5};
		assertTimeout(Duration.ofMillis(10), ()->sa.sortedArray(num));
	}

}
