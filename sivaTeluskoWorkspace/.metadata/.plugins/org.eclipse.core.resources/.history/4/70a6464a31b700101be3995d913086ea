package conditional;

public class whileLoop {

	public static void main(String[] args) {
int i=1;
while(i<=4) {
	System.out.println("Hi : " +i);
	i++;
}
System.out.println("-------------Nested While Loop Starts");
//Nested While Loop
int num=1;
while(num<=4) {
	System.out.println("Hi : " +i);
	int j=1;
	while(j<=num) {
		System.out.println("Hello :"+j);
		j++;
	}
	num++;
}
	}

}
