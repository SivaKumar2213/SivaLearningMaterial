package OOPS;

public class staticVariable {

	public static void main(String[] args) {
Mobile m1=new Mobile();
Mobile m2=new Mobile();
m1.brand="Apple";
m1.price=1500;
m1.type="Smart Phone";
m1.type1="Smart Phone";
m2.brand="Samsung";
m2.price=1000;
m2.type="Smart Phone";

m1.showDetails();
m2.showDetails();

//We can see type is same for all the objects so we can use as a static
	}

}
class Mobile{
	String brand;
	int price;
	String type;
	static String type1;
	
	public void showDetails() {
		System.out.println("Brand : "+brand+ " Price :" +price+" Type :"+type);
	}
}