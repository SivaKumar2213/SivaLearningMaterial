package OOPS;

public class staticBlock {

	public static void main(String[] args) {

	}

}
class Mobile1{
	String name;
	int price;
	static String type;
	
	public Mobile1() {
		name="";
		price=20;
		type="Phone";
		System.out.println("Inside constructor");
	}
	static {
		type="Smart Phone";
		System.out.println("Inside Static Block");
	}
	
}
