package Com.basicsHibernateConnections;

import java.text.SimpleDateFormat;
import java.util.Date;

import org.hibernate.HibernateException;
import org.hibernate.Session;
import org.hibernate.Transaction;
import org.hibernate.cfg.Configuration;

import Com.BasicsHibernate.model.StudentTable;

public class HibernateUsingJavaCodeConnections {

	public static void main(String[] args) {
Configuration config=null;
Session session=null;
Transaction transaction=null;
boolean flag=false;
try {
	config=new Configuration();//After this line in the previous program and all we used config.Configure()
	                           //which will map the properties value from hibernate.cfg.xml
	
	config.setProperty("hibernate.connection.driver_class", "com.mysql.jdbc.Driver");
	config.setProperty("hibernate.connection.password", "Apoorva@2020");
	config.setProperty("hibernate.connection.url", "jdbc:mysql://localhost:3306/jdbclearnsql");
	config.setProperty("hibernate.connection.username", "root");	
	config.setProperty("hibernate.dialect", "org.hibernate.dialect.MySQLDialect");
	config.setProperty("hibernate.hbm2ddl.auto", "update");
	config.setProperty("hibernate.format_sql", "true");
	config.setProperty("hibernate.show_sql", "true");
	//we dont want to call configure method ,because we are directly setting the value in configuration obect and the same will be used further
	session=config.buildSessionFactory().openSession();
	transaction=session.beginTransaction();
	StudentTable st=new StudentTable();
	st.setId(14);
	st.setAge(22);
	st.setCity("Erode");
	st.setName("Gowtham");
	SimpleDateFormat sdf=new SimpleDateFormat("dd-MM-yyyy");
	Date dob = null;
	dob = sdf.parse("22-09-2004");
	st.setDateOfBirth(dob);
	flag=true;
	
	
}
catch(HibernateException e) {
	e.printStackTrace();
}
catch(Exception e1) {
	e1.printStackTrace();
}
finally {
	
}
	}

}
