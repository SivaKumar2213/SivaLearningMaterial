public class constructor {

	public static void main(String[] args) {
Human h=new Human(); 
System.out.println("TheName is : "+h.getName()+ " and the age is : "+h.getAge());	

	}

}
class Human{
	private int age;
	private String name;
	public Human() {
		
	}
	public int getAge() {
		return age;
	}
	public void setAge(int age) {
		this.age = age;
	}
	public String getName() {
		return name;
	}
	public void setName(String name) {
		this.name = name;
	}
	
}
