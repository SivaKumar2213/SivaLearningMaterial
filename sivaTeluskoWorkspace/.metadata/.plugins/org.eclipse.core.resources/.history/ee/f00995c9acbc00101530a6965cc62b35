package OOPS;

public class methodOverloading {

	public static void main(String[] args) {
		Add a=new Add();
		double d=a.add(55.888, 200);
		int d1=(int) a.add(55.888, 200);
		int a1=a.add(1, 4);
		int a2=a.add(1, 2, 3);
		System.out.println("Double :"+d);
		System.out.println("Int :"+a1);
		System.out.println("Int :"+a2);
		System.out.println("Double To Int :"+d1);

		
	}

}

class Add {
	public int add(int n1,int n2) {
		return n1+n2;
	}
	
	/*public double add(int n1,int n2) {
		return n1+n2;
	}*/
	//Even the return type change also we will get compile time error as duplicate method only 
	//the input parameterized and data type of that should be different then only it will allow
	
	public double add(double n1,int n2) {
		return n1+n2;
	}
	
	public int add(int n1,int n2,int n3) {
		return n1+n2+n3;
	}

}
